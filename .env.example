# ── LLM Provider API Keys ────────────────────────────────────────────
# Set the key for your preferred provider. Only one is needed.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Azure OpenAI (both required)
AZURE_RESOURCE_NAME=
AZURE_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# ── Debug ────────────────────────────────────────────────────────────
# Set to "true" or "1" to enable verbose logging
AUTODROID_DEBUG=false
